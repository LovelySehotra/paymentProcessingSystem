# Server Configuration
PORT=1209
NODE_ENV=development
ENV=development
JWT_SECRET=super-secret-jwt-token-key

# Database Connections
DATABASE_URL=mongodb://127.0.0.1:27017/lms
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External Gateway Simulation Probabilities (must sum to 1.0)
GATEWAY_SUCCESS_PROBABILITY=0.70
GATEWAY_TEMPORARY_FAILURE_PROBABILITY=0.10
GATEWAY_HARD_FAILURE_PROBABILITY=0.10
GATEWAY_TIMEOUT_PROBABILITY=0.05
GATEWAY_DELAYED_WEBHOOK_PROBABILITY=0.05

# Webhook Callback Configuration
WEBHOOK_URL=http://localhost:1209/api/webhooks
WEBHOOK_SECRET=super-secret-webhook-signing-key
